{
  "name": "toprouter",
  "version": "1.0.0",
  "type": "module",
  "description": "High-performance, payment-free AI intelligent routing gateway",
  "main": "dist/index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "dev": "nodemon --watch src --ext ts --exec \"node --loader ts-node/esm src/server.ts\"",
    "start": "node dist/server.js",
    "test": "node --loader ts-node/esm test-classifier.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "ai",
    "router",
    "gateway",
    "classification",
    "multilingual"
  ],
  "author": "yangjianforwork",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^25.3.2",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.13.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lru-cache": "^11.0.2",
    "zod": "^3.24.1"
  }
}
