# Server configuration
PORT=94527
NODE_ENV=development

# Cache settings
CACHE_MAX_SIZE=1000
CACHE_TTL_MS=3600000  # 1 hour in milliseconds

# LLM API keys for L2 fallback classification
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com
GEMINI_API_KEY=your_gemini_api_key_here

# Classification confidence threshold (0-1)
CONFIDENCE_THRESHOLD=0.7

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000    # 1 minute in milliseconds
RATE_LIMIT_MAX=100             # max requests per window

# Quota management
ENABLE_QUOTA=false             # enable API key quota checking
API_KEYS=sk_test_1,sk_test_2   # comma-separated API keys
DEFAULT_DAILY_TOKEN_LIMIT=1000000    # 1M tokens per day per key
DEFAULT_MONTHLY_TOKEN_LIMIT=30000000 # 30M tokens per month per key
QUOTA_RESET_HOUR=0             # UTC hour (0-23) to reset daily quota

# Redis (optional, for distributed quota storage)
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your_redis_password